{
  "name": "@libraz/formulon-cell",
  "version": "0.1.0",
  "description": "Spreadsheet UI for the formulon WASM calc engine — extension-based, i18n-aware, theme-tokenized, and desktop-spreadsheet-style.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "libraz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/libraz/formulon-cell.git",
    "directory": "packages/formulon-cell"
  },
  "homepage": "https://github.com/libraz/formulon-cell",
  "bugs": "https://github.com/libraz/formulon-cell/issues",
  "keywords": [
    "spreadsheet",
    "workbook",
    "xlsx",
    "formula",
    "canvas",
    "headless-ui",
    "datagrid",
    "wasm",
    "i18n"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./extensions": {
      "types": "./dist/extensions/index.d.ts",
      "import": "./dist/extensions/index.js"
    },
    "./extensions/*": {
      "types": "./dist/extensions/*.d.ts",
      "import": "./dist/extensions/*.js"
    },
    "./i18n/*": {
      "types": "./dist/i18n/*.d.ts",
      "import": "./dist/i18n/*.js"
    },
    "./styles.css": "./dist/styles/index.css",
    "./styles/paper.css": "./dist/styles/theme-paper.css",
    "./styles/ink.css": "./dist/styles/theme-ink.css",
    "./styles/contrast.css": "./dist/styles/theme-contrast.css",
    "./styles/tokens.css": "./dist/styles/tokens.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "vite build && node scripts/copy-styles.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@libraz/formulon": "0.9.0"
  },
  "peerDependencies": {
    "zustand": "^5"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.5",
    "happy-dom": "20.9.0",
    "typescript": "6.0.3",
    "unplugin-dts": "1.0.0",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "zustand": "^5"
  }
}
