{
  "name": "@libraz/formulon-cell-react",
  "version": "0.2.0",
  "description": "React 18+ component + hooks for @libraz/formulon-cell.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "libraz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/libraz/formulon-cell.git",
    "directory": "packages/formulon-cell-react"
  },
  "homepage": "https://github.com/libraz/formulon-cell",
  "bugs": "https://github.com/libraz/formulon-cell/issues",
  "keywords": [
    "spreadsheet",
    "react",
    "workbook",
    "datagrid",
    "formulon-cell"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./toolbar.css": "./src/spreadsheet-toolbar.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/spreadsheet-toolbar.css",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fluentui/react-icons": "^2.0.325",
    "@libraz/formulon-cell": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8",
    "typescript": "6.0.3"
  }
}
