{
  "name": "@libraz/formulon-cell-vue",
  "version": "0.1.1",
  "description": "Vue 3 component + composables for @libraz/formulon-cell.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "libraz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/libraz/formulon-cell.git",
    "directory": "packages/formulon-cell-vue"
  },
  "homepage": "https://github.com/libraz/formulon-cell",
  "bugs": "https://github.com/libraz/formulon-cell/issues",
  "keywords": [
    "spreadsheet",
    "vue",
    "workbook",
    "datagrid",
    "formulon-cell"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./toolbar.vue": {
      "types": "./src/SpreadsheetToolbar.vue.d.ts",
      "import": "./src/SpreadsheetToolbar.vue"
    },
    "./toolbar.css": "./src/spreadsheet-toolbar.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/SpreadsheetToolbar.vue",
    "src/SpreadsheetToolbar.vue.d.ts",
    "src/spreadsheet-toolbar.css",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "*.vue",
    "*.css"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@libraz/formulon-cell": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8",
    "typescript": "6.0.3",
    "vue": "^3.5"
  }
}
